{
  "name": "yjs-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Notezy internal Yjs collaboration worker",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "tsx --test test/*.test.ts",
    "format:all": "biome check --write src test",
    "format:check": "biome check src test"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "error"
    }
  },
  "type": "module",
  "dependencies": {
    "@blocknote/core": "0.51.3",
    "@hono/node-server": "^2.0.8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "hono": "^4.12.30",
    "ws": "^8.18.3",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.15.30",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
